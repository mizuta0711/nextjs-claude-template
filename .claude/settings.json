{
  "env": {
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "200000"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(npx prisma migrate:*)",
            "command": "node -e \"const{execSync}=require('child_process');try{execSync('npx tsx tools/export-to-sql.ts',{stdio:'inherit',timeout:30000});console.log(JSON.stringify({systemMessage:'DB backup completed before migrate.'}))}catch(e){console.log(JSON.stringify({continue:false,stopReason:'DB backup failed. Fix before running migrate: '+e.message}))}\"",
            "timeout": 60,
            "statusMessage": "Running DB backup before migrate..."
          },
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "node .claude/hooks/pre-commit-type-check.js",
            "timeout": 120,
            "statusMessage": "Running type check before commit..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "node .claude/hooks/post-commit-doc-check.js",
            "timeout": 10,
            "statusMessage": "Checking doc sync..."
          }
        ]
      }
    ]
  }
}
