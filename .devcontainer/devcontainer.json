{
  "name": "nextjs-claude-template",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",

  // WSL から VS Code を起動した場合のみ HOME が WSL ホームを指す
  // Windows 側から直接開くと Windows の USERPROFILE になるため、必ず WSL から起動すること
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude.json,target=/home/node/.claude.json,type=bind,consistency=cached"
  ],

  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "postCreateCommand": "git config core.autocrlf input && npm install -g @anthropic-ai/claude-code",

  "remoteUser": "node"
}
